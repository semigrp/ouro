{
  "name": "@semigrp/ouro",
  "version": "0.1.0",
  "description": "A local-first outbound execution engine for reproducible AI-agent loops.",
  "type": "module",
  "bin": {
    "ouro": "./dist/bin/ouro.js"
  },
  "files": [
    "dist/src",
    "dist/bin",
    "contracts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json && chmod +x dist/bin/ouro.js",
    "test": "pnpm run build && node --test dist/test/*.test.js",
    "doctor": "pnpm run build && node ./dist/bin/ouro.js doctor",
    "demo": "pnpm run build && node ./dist/bin/ouro.js demo"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/semigrp/ouro.git"
  },
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  }
}
